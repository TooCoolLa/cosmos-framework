{
  "$defs": {
    "BlurTransferOverrides": {
      "additionalProperties": false,
      "properties": {
        "control_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path or URL to pre-computed control input.",
          "title": "Control Path"
        },
        "preset_blur_strength": {
          "anyOf": [
            {
              "$ref": "#/$defs/PresetBlurStrength"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Blur strength preset."
        }
      },
      "title": "BlurTransferOverrides",
      "type": "object"
    },
    "CheckpointDirHf": {
      "additionalProperties": false,
      "description": "Config for checkpoint directory on Hugging Face.",
      "properties": {
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "repository": {
          "title": "Repository",
          "type": "string"
        },
        "repository_type": {
          "$ref": "#/$defs/RepositoryType",
          "default": "model"
        },
        "revision": {
          "title": "Revision",
          "type": "string"
        },
        "subdirectory": {
          "default": "",
          "title": "Subdirectory",
          "type": "string"
        },
        "include": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Include",
          "type": "array"
        },
        "exclude": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Exclude",
          "type": "array"
        }
      },
      "required": [
        "repository",
        "revision"
      ],
      "title": "CheckpointDirHf",
      "type": "object"
    },
    "CheckpointType": {
      "description": "Checkpoint type.",
      "enum": [
        "hf",
        "dcp"
      ],
      "title": "CheckpointType",
      "type": "string"
    },
    "ConfigFileType": {
      "description": "Config file type.",
      "enum": [
        "module",
        "yaml",
        "json"
      ],
      "title": "ConfigFileType",
      "type": "string"
    },
    "EdgeTransferOverrides": {
      "additionalProperties": false,
      "properties": {
        "control_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path or URL to pre-computed control input.",
          "title": "Control Path"
        },
        "preset_edge_threshold": {
          "anyOf": [
            {
              "$ref": "#/$defs/PresetEdgeThreshold"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Edge detection threshold preset."
        }
      },
      "title": "EdgeTransferOverrides",
      "type": "object"
    },
    "ModelMode": {
      "enum": [
        "text2image",
        "text2video",
        "image2image",
        "image2video",
        "video2video",
        "forward_dynamics",
        "inverse_dynamics",
        "policy"
      ],
      "title": "ModelMode",
      "type": "string"
    },
    "NegativeMetadataMode": {
      "enum": [
        "none",
        "same",
        "inverse"
      ],
      "title": "NegativeMetadataMode",
      "type": "string"
    },
    "OmniSampleOverrides": {
      "additionalProperties": false,
      "properties": {
        "prompt_upsampling": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If True, replace the prompt with a dense JSON prompt.",
          "title": "Prompt Upsampling"
        },
        "prompt_upsampler_max_tokens": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum tokens generated by the prompt upsampler.",
          "title": "Prompt Upsampler Max Tokens"
        },
        "prompt_upsampler_temperature": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Native prompt upsampler sampling temperature.",
          "title": "Prompt Upsampler Temperature"
        },
        "prompt_upsampler_top_p": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Native prompt upsampler nucleus sampling probability.",
          "title": "Prompt Upsampler Top P"
        },
        "prompt_upsampler_top_k": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Native prompt upsampler top-k sampling limit.",
          "title": "Prompt Upsampler Top K"
        },
        "prompt_upsampler_repetition_penalty": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Native prompt upsampler CTRL/HF-style multiplicative repetition penalty (>0).",
          "title": "Prompt Upsampler Repetition Penalty"
        },
        "prompt_upsampler_presence_penalty": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Native prompt upsampler OpenAI-style additive presence penalty (any sign).",
          "title": "Prompt Upsampler Presence Penalty"
        },
        "prompt_upsampler_seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional integer seed for the native prompt upsampler's sampling RNG.",
          "title": "Prompt Upsampler Seed"
        },
        "prompt_upsampler_variant": {
          "anyOf": [
            {
              "enum": [
                "8B",
                "32B"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Prompt upsampler variant. Defaults to the VFM model size for 8B/32B models.",
          "title": "Prompt Upsampler Variant"
        },
        "prompt_upsampler_endpoint_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Advanced override for the OpenAI-compatible prompt upsampler endpoint URL.",
          "title": "Prompt Upsampler Endpoint Url"
        },
        "prompt_upsampling_applied": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Internal idempotency marker set after prompt upsampling has already run.",
          "title": "Prompt Upsampling Applied"
        },
        "autoregressive": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If True, use autoregressive per-frame generation.",
          "title": "Autoregressive"
        },
        "sigma_diffusion_forcing": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Post-shift sigma used to seed clean context frames into the KV cache under\ndiffusion_forcing AR inference. Overrides model.config.sigma_diffusion_forcing when set.\nIgnored when causal_training_strategy != 'diffusion_forcing'.",
          "title": "Sigma Diffusion Forcing"
        },
        "camera_trajectory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Camera trajectory string parsed by ``parse_camera_string``\n(e.g. 'w-30,right-15,w-15'). Mutually exclusive with ``action_path``;\nonly valid for ``action_mode='forward_dynamics'``.",
          "title": "Camera Trajectory"
        },
        "edge": {
          "anyOf": [
            {
              "$ref": "#/$defs/EdgeTransferOverrides"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Edge transfer control configuration."
        },
        "blur": {
          "anyOf": [
            {
              "$ref": "#/$defs/BlurTransferOverrides"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Blur transfer control configuration."
        },
        "depth": {
          "anyOf": [
            {
              "$ref": "#/$defs/TransferOverrides"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Depth transfer control configuration."
        },
        "seg": {
          "anyOf": [
            {
              "$ref": "#/$defs/TransferOverrides"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Segmentation transfer control configuration."
        },
        "wsm": {
          "anyOf": [
            {
              "$ref": "#/$defs/TransferOverrides"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "World Scenario Map (hdmap_bbox) transfer control configuration."
        },
        "num_video_frames_per_chunk": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Number of video frames per autoregressive chunk.",
          "title": "Num Video Frames Per Chunk"
        },
        "num_conditional_frames": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Number of conditional frames from the previous chunk for autoregressive generation.",
          "title": "Num Conditional Frames"
        },
        "max_frames": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum number of input frames to read.",
          "title": "Max Frames"
        },
        "show_control_condition": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If True, concatenate control video in the output.",
          "title": "Show Control Condition"
        },
        "show_input": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If True, concatenate input video in the output.",
          "title": "Show Input"
        },
        "num_first_chunk_conditional_frames": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Number of frames from vision_path to condition on in the first chunk.\n0 = t2v (no conditioning), 1 = i2v, >1 = v2v.",
          "title": "Num First Chunk Conditional Frames"
        },
        "share_vision_temporal_positions": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If True, all vision items in a transfer sample share one temporal mRoPE grid\n(controlnet-style: control frame k and target frame k get the same temporal id).\nMust match the regime the checkpoint was trained under \u2014 checkpoints trained with\nthe temporal-id-fix require True, ablation `*_no_temporal_share_*` checkpoints\nrequire False. Defaults to True via `_TRANSFER_SAMPLE_DEFAULTS`.",
          "title": "Share Vision Temporal Positions"
        },
        "action_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path to action JSON file. Required for forward_dynamics mode.",
          "title": "Action Path"
        },
        "domain_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Action domain name passed to get_domain_id().",
          "title": "Domain Name"
        },
        "image_size": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Target image height in pixels (aspect-ratio-preserving resize).",
          "title": "Image Size"
        },
        "action_chunk_size": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Number of action steps to predict.",
          "title": "Action Chunk Size"
        },
        "raw_action_dim": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Dimension of the raw action data. Required when action_path is not provided.",
          "title": "Raw Action Dim"
        },
        "enable_sound": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Enable joint video+sound generation (t2vs mode). Requires a checkpoint with sound modules.",
          "title": "Enable Sound"
        },
        "vision_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path or URL to conditioning image/video.",
          "title": "Vision Path"
        },
        "condition_frame_indexes_vision": {
          "anyOf": [
            {
              "items": {
                "type": "integer"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Latent frame indices to condition on. Defaults to [0] for image, [0, 1] for video.",
          "title": "Condition Frame Indexes Vision"
        },
        "condition_video_keep": {
          "anyOf": [
            {
              "enum": [
                "first",
                "last"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether to take the first or last ``max_frames`` of the conditioning\nvideo when it is longer than needed. Defaults to ``\"first\"``. No effect\non image conditioning.",
          "title": "Condition Video Keep"
        },
        "resolution": {
          "anyOf": [
            {
              "enum": [
                "256",
                "480",
                "720",
                "768",
                "1080"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Vision resolution.\n\nDefaults to model config resolution.",
          "title": "Resolution"
        },
        "aspect_ratio": {
          "anyOf": [
            {
              "enum": [
                "1,1",
                "4,3",
                "3,4",
                "16,9",
                "9,16"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Vision aspect ratio. When None, image_edit preserves the input image's native\naspect ratio; all other modes default to 16:9.",
          "title": "Aspect Ratio"
        },
        "fps": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Vision frames per second. Recommended range [10, 30]; quality may be degraded outside of this range.",
          "title": "Fps"
        },
        "num_frames": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Number of vision frames.\n\nRange by resolution: 256p: [24, 400], 480p: [24, 300], 720p/768p: [24, 200].\nImage-only resolutions (e.g. 1080p) require num_frames=1.",
          "title": "Num Frames"
        },
        "video_save_quality": {
          "anyOf": [
            {
              "maximum": 10,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Quality of the saved video (0-10).",
          "title": "Video Save Quality"
        },
        "image_save_quality": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Quality of the saved image (0-100).",
          "title": "Image Save Quality"
        },
        "prompt_path": {
          "anyOf": [
            {
              "format": "file-path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path to a .txt file containing the prompt. Only one of 'prompt' or 'prompt_path' should be provided.",
          "title": "Prompt Path"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Text prompt for generation. Only one of 'prompt' or 'prompt_path' should be provided.",
          "title": "Prompt"
        },
        "negative_prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Negative prompt - describing what you don't want in the generated video.",
          "title": "Negative Prompt"
        },
        "duration_template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Template string for appending duration/fps to prompt. Use {duration} and {fps} placeholders.",
          "title": "Duration Template"
        },
        "resolution_template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Template string for appending resolution to prompt. Use {height} and {width} placeholders.",
          "title": "Resolution Template"
        },
        "negative_metadata_mode": {
          "anyOf": [
            {
              "$ref": "#/$defs/NegativeMetadataMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Negative prompt metadata mode: 'none', 'same', or 'inverse'."
        },
        "inverse_duration_template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inverse template for duration/fps metadata in the negative prompt.",
          "title": "Inverse Duration Template"
        },
        "inverse_resolution_template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inverse template for resolution metadata in the negative prompt.",
          "title": "Inverse Resolution Template"
        },
        "negative_prompt_keep_metadata": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Compatibility flag. If True and mode is 'none', mode is promoted to 'same'.",
          "title": "Negative Prompt Keep Metadata"
        },
        "model_mode": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Generation modality. When omitted, the VFM modality is inferred from ``vision_path`` and\n``num_frames``; action modes must be set explicitly."
        },
        "num_steps": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Number of steps for the diffusion model.",
          "title": "Num Steps"
        },
        "guidance": {
          "anyOf": [
            {
              "maximum": 7,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Guidance scale for the diffusion model.",
          "title": "Guidance"
        },
        "guidance_interval": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "minimum": 0,
                  "type": "number"
                },
                {
                  "minimum": 0,
                  "type": "number"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Guidance interval for the diffusion model.",
          "title": "Guidance Interval"
        },
        "normalize_cfg": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If True, normalize the CFG output.",
          "title": "Normalize Cfg"
        },
        "shift": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Shift in the UniPC sampler. Ignored when sampler='edm'.",
          "title": "Shift"
        },
        "sigma_max": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum sigma for the EDM sampler. Ignored when sampler='unipc'.",
          "title": "Sigma Max"
        },
        "output_dir": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Output directory.",
          "title": "Output Dir"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Model name.",
          "title": "Model"
        },
        "extra": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Extra arguments.",
          "title": "Extra"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name of the sample.",
          "title": "Name"
        },
        "num_outputs": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Number of outputs to generate per sample.",
